{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${mod_version}",
    "name": "${mod_name}",
    "description": "${mod_description}",
    "authors": [
        "${mod_author}"
    ],
    "contact": {
        "homepage": "${mod_homepage}",
        "sources": "${mod_sources}",
        "issues": "${mod_issues}"
    },
    "license": "${mod_license}",
    "icon": "${mod_id}.png",
    "environment": "*",
    "accessWidener": "${mod_id}.classtweaker",
    "entrypoints": {
        "main": [
            "io.github.simonxwei.${mod_id}.TemplateMod"
        ],
        "client": [
            "io.github.simonxwei.${mod_id}.client.TemplateModClient"
        ],
        "fabric-datagen": [
            "io.github.simonxwei.${mod_id}.client.TemplateModDataGenerator"
        ]
    },
    "mixins": [
        "${mod_id}.mixins.json",
        "${mod_id}.fabric.mixins.json",
        {
            "config": "${mod_id}.fabric.client.mixins.json",
            "environment": "client"
        }
    ],
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "minecraft": "~${minecraft_version}",
        "java": ">=${java_version}",
        "fabric-api": "*"
    }
}